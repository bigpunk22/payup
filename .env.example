# Option 1: Neon PostgreSQL (Recommended)
DATABASE_URL=postgresql://username:password@ep-xxx-xxx.us-east-1.aws.neon.tech/dbname?sslmode=require

# Option 2: Traditional PostgreSQL
# DB_USER=postgres
# DB_HOST=localhost
# DB_NAME=voucher_remittance
# DB_PASSWORD=password
# DB_PORT=5432

# Paystack Payment Configuration
PAYSTACK_SECRET_KEY=your_paystack_secret_key_here
PAYSTACK_PUBLIC_KEY=your_paystack_public_key_here

# Authentication Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
RESET_TOKEN_SECRET=your-reset-token-secret-change-in-production

# Email Configuration (for password reset)
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-app-password-goes-here

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
